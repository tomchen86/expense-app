{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathIgnorePatterns=integration\\.test",
    "test:unit:fast": "jest --bail --onlyChanged --passWithNoTests --testPathIgnorePatterns=integration\\.test",
    "test:integration": "jest --runInBand --testPathPattern=integration\\.test",
    "test:component": "jest --runInBand --testPathPattern=components/__tests__/",
    "test:performance": "jest --runInBand --testPathPattern=__tests__/performance",
    "test:coverage": "jest --coverage",
    "test:coverage:html": "jest --coverage --coverageReporters=text-summary --coverageReporters=lcov --coverageReporters=html --coverageReporters=html-spa",
    "test:coverage-check": "jest --coverage --runInBand",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build",
    "test:all": "./scripts/test-all.sh",
    "test:all:e2e": "./scripts/test-all.sh --e2e",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "expo": "55.0.4",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.3",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.64",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "^0.7.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@eslint/js": "^9.36.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.5.2",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "^55.0.10",
    "detox": "^20.42.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "expect": "29.7.0",
    "expo-doctor": "^1.17.8",
    "globals": "^16.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-expo": "^55.0.9",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.44.1",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "private": true
}
