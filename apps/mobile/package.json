{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node --expose-gc ./node_modules/jest/bin/jest.js",
    "test:watch": "node --expose-gc ./node_modules/jest/bin/jest.js --watch",
    "test:unit": "node --expose-gc ./node_modules/jest/bin/jest.js --selectProjects unit",
    "test:unit:fast": "node --expose-gc ./node_modules/jest/bin/jest.js --selectProjects unit --bail --onlyChanged --passWithNoTests",
    "test:integration": "node --expose-gc ./node_modules/jest/bin/jest.js --selectProjects integration --runInBand",
    "test:component": "node --expose-gc ./node_modules/jest/bin/jest.js --selectProjects unit --runInBand --testPathPatterns=components/__tests__/",
    "test:performance": "node --expose-gc ./node_modules/jest/bin/jest.js --selectProjects unit --runInBand --testPathPatterns=__tests__/performance",
    "test:coverage": "node --expose-gc ./node_modules/jest/bin/jest.js --coverage",
    "test:coverage:html": "node --expose-gc ./node_modules/jest/bin/jest.js --coverage --coverageReporters=text-summary --coverageReporters=lcov --coverageReporters=html --coverageReporters=html-spa",
    "test:coverage-check": "node --expose-gc ./node_modules/jest/bin/jest.js --coverage --runInBand",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build",
    "test:all": "./scripts/test-all.sh",
    "test:all:e2e": "./scripts/test-all.sh --e2e",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo/dom-webview": "^57.0.0",
    "@expo/metro-runtime": "^57.0.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-picker/picker": "2.11.4",
    "expo": "57.0.4",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "babel-jest": "^30.4.1",
    "babel-preset-expo": "^57.0.2",
    "detox": "^20.51.4",
    "eslint": "10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "expect": "29.7.0",
    "expo-doctor": "^1.20.0",
    "globals": "^17.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-expo": "^57.0.1",
    "prettier": "^3.9.5",
    "react-test-renderer": "19.2.3",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.63.0",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "private": true
}
