{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expense-app.local/workflow/ci-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "bootstrapExceptions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "bootstrapExceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "changeId",
          "taskIds",
          "compatibilityCommits",
          "introductionPaths",
          "allowedPaths"
        ],
        "properties": {
          "changeId": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "taskIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^\\d+(?:\\.\\d+)+$" }
          },
          "compatibilityCommits": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["taskId", "subject", "changedPaths"],
              "properties": {
                "taskId": {
                  "type": "string",
                  "pattern": "^\\d+(?:\\.\\d+)+$"
                },
                "subject": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200,
                  "pattern": "^[^\\r\\n\\u0000]+$"
                },
                "changedPaths": { "$ref": "#/$defs/paths" }
              }
            }
          },
          "introductionPaths": {
            "$ref": "#/$defs/paths"
          },
          "allowedPaths": {
            "$ref": "#/$defs/paths"
          }
        }
      }
    }
  },
  "$defs": {
    "paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
