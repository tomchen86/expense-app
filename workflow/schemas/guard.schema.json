{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expense-app.local/workflow/guard.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "changeId", "tasks"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "changeId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "tasks": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^\\d+(?:\\.\\d+)+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["allowedPaths", "requiredChecks"],
        "properties": {
          "allowedPaths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!\\s)(?!.*\\s$)(?!/)(?![A-Za-z]:[\\\\/])(?!\\.[gG][iI][tT](?:/|$))(?!.*\\/\\.[gG][iI][tT](?:/|$))(?!\\.{1,2}(?:/|$))(?!.*\\/\\.{1,2}(?:/|$))(?!.*//)(?!.*\\/$)(?!.*[\\\\?\\[\\]{}!\\u0000-\\u001F\\u007F-\\u009F])[^*]+(?:/\\*\\*)?$"
            }
          },
          "requiredChecks": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          }
        }
      }
    }
  }
}
