{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expense-app.local/workflow/guard.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "changeId", "tasks"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "changeId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "tasks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["allowedPaths", "requiredChecks"],
        "properties": {
          "allowedPaths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "requiredChecks": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
